generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum Category {
  OVERALL
  LADIES
  C2
  C3
}

enum PrizeType {
  CASH
  VOUCHER
}

model Member {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  results   Result[]
  orders    Order[]
}

model Race {
  id           String   @id @default(uuid())
  round        Int      @unique
  date         DateTime
  time         String
  isParaCycling Boolean @default(false)
  createdAt    DateTime @default(now())
  results      Result[]
}

model Result {
  id                String    @id @default(uuid())
  race              Race      @relation(fields: [raceId], references: [id])
  raceId            String
  member            Member    @relation(fields: [memberId], references: [id])
  memberId          String
  category          Category
  position          Int
  prizeType         PrizeType
  prizeAmount       Float?
  voucherSponsor    String?
  notificationSent  Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Order {
  id        String   @id @default(uuid())
  member    Member   @relation(fields: [memberId], references: [id])
  memberId  String
  items     String[]
  status    String   @default("pending")
  createdAt DateTime @default(now())
}